# Clone account credentials — auto-login khi cookies hết hạn
FB_EMAIL=clone_account@gmail.com
FB_PASSWORD=your_password_here

# Nhiều acc clone: dùng acc nào đầu tiên tìm thấy cookies còn hạn
# FB_EMAIL_2=clone2@gmail.com
# FB_PASSWORD_2=password2

# Optional: proxy
PROXY_SERVER=http://user:pass@host:port
