# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Facebook clone/research account credentials
# Used by: python main.py login --email $FB_EMAIL
# Also read automatically by the scraper for session re-login
FB_EMAIL=your_clone_account@gmail.com
FB_PASSWORD=your_password_here

# Additional accounts (optional) — used if FB_EMAIL session is banned
# FB_EMAIL_2=clone2@gmail.com
# FB_PASSWORD_2=password2

# Optional: proxy server for IP rotation
# Format: http://user:pass@host:port
# Enable in config.yaml: proxy.enabled: true
PROXY_SERVER=

# Override default cookies file path (used by collect_urls.py single mode)
# COOKIES_OVERRIDE=cookies/session_3.json
